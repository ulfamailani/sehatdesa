# Railway otomatis menyediakan variable ini kalau kamu add MySQL plugin
# di project yang sama. Kamu TIDAK perlu isi manual, cukup pastikan
# nama variable-nya persis seperti ini (bisa dicek di tab "Variables"
# service MySQL kamu di Railway).
MYSQLHOST=
MYSQLDATABASE=
MYSQLUSER=
MYSQLPASSWORD=
MYSQLPORT=

# Opsional: kalau mau APP_SECRET beda dari default, set manual di
# tab Variables service PHP kamu.
APP_SECRET=
