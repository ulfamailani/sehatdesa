<?php
require_once __DIR__ . '/../includes/db.php';
require_once __DIR__ . '/../includes/auth.php';
require_once __DIR__ . '/../includes/functions.php';

header('Content-Type: application/json; charset=utf-8');

$user = current_user();
if (!$user) {
    http_response_code(401);
    echo json_encode(['error' => 'Silakan masuk terlebih dahulu.']);
    exit;
}

$input = json_decode(file_get_contents('php://input'), true);
$pesan = isset($input['pesan']) ? trim($input['pesan']) : '';

if ($pesan === '') {
    http_response_code(422);
    echo json_encode(['error' => 'Pertanyaan tidak boleh kosong.']);
    exit;
}
if (mb_strlen($pesan) > 2000) {
    http_response_code(422);
    echo json_encode(['error' => 'Pertanyaan terlalu panjang (maksimal 2000 karakter).']);
    exit;
}

$settings = get_api_settings();
if (!$settings || $settings['api_key'] === '' || $settings['api_key'] === 'GANTI_DENGAN_API_KEY_ANDA') {
    http_response_code(500);
    echo json_encode(['error' => 'API key belum diatur. Hubungi admin untuk mengatur di halaman Pengaturan.']);
    exit;
}

$systemPrompt = 'Anda adalah Asisten SehatDesa, asisten edukasi kesehatan dasar untuk masyarakat desa di Indonesia. '
    . 'Jawab dalam Bahasa Indonesia yang sederhana dan mudah dipahami warga desa. '
    . 'Berikan informasi edukatif seputar gejala umum, gizi keluarga, dan pencegahan penyakit. '
    . 'JANGAN memberikan diagnosis medis pasti atau meresepkan obat/dosis. '
    . 'Untuk gejala berat, tanda bahaya, atau kondisi yang tidak membaik, selalu sarankan segera periksa ke Puskesmas atau fasilitas kesehatan terdekat.';

$ch = curl_init('https://api.anthropic.com/v1/messages');
curl_setopt_array($ch, [
    CURLOPT_RETURNTRANSFER => true,
    CURLOPT_POST => true,
    CURLOPT_HTTPHEADER => [
        'Content-Type: application/json',
        'x-api-key: ' . $settings['api_key'],
        'anthropic-version: 2023-06-01',
    ],
    CURLOPT_POSTFIELDS => json_encode([
        'model' => $settings['model'] ?: 'claude-sonnet-5',
        'max_tokens' => 600,
        'system' => $systemPrompt,
        'messages' => [
            ['role' => 'user', 'content' => $pesan],
        ],
    ]),
    CURLOPT_TIMEOUT => 30,
]);

$response  = curl_exec($ch);
$httpCode  = curl_getinfo($ch, CURLINFO_HTTP_CODE);
$curlErr   = curl_error($ch);
curl_close($ch);

if ($curlErr) {
    http_response_code(502);
    echo json_encode(['error' => 'Gagal terhubung ke layanan AI: ' . $curlErr]);
    exit;
}

$data = json_decode($response, true);

if ($httpCode !== 200 || !isset($data['content'][0]['text'])) {
    http_response_code(502);
    $msg = (isset($data['error']['message']) && $data['error']['message'] !== '')
        ? $data['error']['message']
        : 'Layanan AI mengembalikan respons yang tidak terduga.';
    echo json_encode(['error' => $msg]);
    exit;
}

$jawaban = $data['content'][0]['text'];

$stmt = db()->prepare('INSERT INTO chat_history (user_id, pesan, jawaban) VALUES (?,?,?)');
$stmt->execute([$user['id'], $pesan, $jawaban]);

echo json_encode(['jawaban' => $jawaban]);
